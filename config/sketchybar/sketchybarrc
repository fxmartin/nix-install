           --set wifi display=1 update_freq=10 icon=󰤨 icon.font="Hack Nerd Font:Bold:15.0" label.drawing=off click_script="open x-apple.systempreferences:com.apple.wifi-settings-extension" script="$PLUGIN_DIR/wifi.sh" \
