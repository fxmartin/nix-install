#!/usr/bin/env bash
# ABOUTME: Local pre-push gate for release version metadata
# ABOUTME: Blocks pushes when VERSION, README.md, CLAUDE.md, and CHANGELOG.md drift

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
"${ROOT_DIR}/scripts/verify-version.sh"

version="$(tr -d '[:space:]' < "${ROOT_DIR}/VERSION")"
if ! grep -Eq "^## \\[${version}\\] - [0-9]{4}-[0-9]{2}-[0-9]{2}$" "${ROOT_DIR}/CHANGELOG.md"; then
    echo "release check failed: CHANGELOG.md has no dated section for VERSION ${version}" >&2
    exit 1
fi
